{
	"name": "@mindos/sdk",
	"version": "0.1.0",
	"description": "TypeScript SDK for mindOS — the open-source AI memory engine",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist .turbo"
	},
	"dependencies": {},
	"devDependencies": {
		"typescript": "^5.7.0"
	},
	"license": "MIT",
	"keywords": ["ai", "memory", "llm", "rag", "vector-search", "mindos"],
	"repository": {
		"type": "git",
		"url": "https://github.com/sajdakabir/mindOS"
	}
}
